# PHP
packages/php/vendor/
# Lock files are intentionally excluded for library packages.
# Libraries should test against dependency ranges to catch compatibility issues early.
# See: https://getcomposer.org/doc/02-libraries.md#lock-file
packages/php/composer.lock
packages/php/.phpunit.cache/
packages/php/.php-cs-fixer.cache
packages/php/.phpstan.cache/

# JS/TS
packages/js/node_modules/
packages/js/dist/
packages/js/coverage/
# Lock files are intentionally excluded for library packages.
# See: https://docs.npmjs.com/cli/v10/configuring-npm/package-lock-json#package-lockjson-vs-npm-shrinkwrapjson
packages/js/package-lock.json

# Root tooling (husky, commitlint, lint-staged)
node_modules/
package-lock.json

