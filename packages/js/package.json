{
    "name": "@safe-access-inline/safe-access-inline",
    "version": "0.3.1",
    "description": "Safe nested data access with dot notation — supports Object, Array, JSON, XML, YAML and more.",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:mutation": "stryker run",
        "test:typecheck": "vitest run --typecheck tests/types.test-d.ts",
        "test:property": "vitest run tests/property.test.ts",
        "test:fuzzing": "vitest run tests/fuzzing.test.ts",
        "test:snapshot": "vitest run tests/snapshot.test.ts",
        "test:parity": "vitest run tests/cross-parity.test.ts",
        "bench": "vitest bench benchmarks/",
        "lint": "eslint src/ tests/",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write src/ tests/"
    },
    "keywords": [
        "safe-access",
        "dot-notation",
        "nested-data",
        "typescript",
        "json",
        "yaml",
        "schema",
        "plugins"
    ],
    "license": "MIT",
    "author": "Felipe Sauer (https://github.com/felipesauer)",
    "repository": {
        "type": "git",
        "url": "https://github.com/felipesauer/safe-access-inline.git",
        "directory": "packages/js"
    },
    "homepage": "https://github.com/felipesauer/safe-access-inline#readme",
    "bugs": {
        "url": "https://github.com/felipesauer/safe-access-inline/issues"
    },
    "funding": {
        "type": "github",
        "url": "https://github.com/sponsors/felipesauer"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "peerDependencies": {
        "js-yaml": "^4.0.0",
        "smol-toml": "^1.0.0"
    },
    "peerDependenciesMeta": {
        "js-yaml": {
            "optional": true
        },
        "smol-toml": {
            "optional": true
        }
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stryker-mutator/core": "^9.6.0",
        "@stryker-mutator/vitest-runner": "^9.6.0",
        "@types/js-yaml": "^4.0.0",
        "@types/node": "^25.5.0",
        "@vitest/coverage-v8": "^4.1.0",
        "eslint": "^10.0",
        "expect-type": "^1.3.0",
        "fast-check": "^4.6.0",
        "js-yaml": "^4.0.0",
        "prettier": "^3.0",
        "smol-toml": "^1.0.0",
        "tsup": "^8.0",
        "typescript": "^5.5",
        "typescript-eslint": "^8.57.0",
        "vitest": "^4.1"
    },
    "engines": {
        "node": ">=22"
    }
}
