{
    "name": "safe-access-inline/safe-access-inline",
    "version": "0.3.1",
    "description": "Safe nested data access with dot notation — supports Array, Object, JSON, XML, YAML, TOML, INI, CSV, ENV.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "safe-access",
        "dot-notation",
        "nested-data",
        "laravel",
        "json",
        "yaml",
        "schema",
        "plugins"
    ],
    "homepage": "https://github.com/felipesauer/safe-access-inline",
    "authors": [
        {
            "name": "Felipe Sauer",
            "email": "felipesauer11@hotmail.com",
            "homepage": "https://github.com/felipesauer"
        }
    ],
    "support": {
        "issues": "https://github.com/felipesauer/safe-access-inline/issues",
        "source": "https://github.com/felipesauer/safe-access-inline/tree/main/packages/php"
    },
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-simplexml": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "suggest": {
        "ext-yaml": "Preferred YAML engine — when installed, used automatically over symfony/yaml for better performance",
        "symfony/yaml": "Required for YAML parsing when ext-yaml is not available (^7.0)",
        "devium/toml": "Required for TOML parsing (^1.0)"
    },
    "autoload": {
        "psr-4": {
            "SafeAccessInline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SafeAccessInline\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/pest --coverage-html coverage --coverage-clover coverage.xml",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix",
        "bench": "php benchmarks/dot-notation.php"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SafeAccessInline\\Integrations\\LaravelServiceProvider"
            ],
            "aliases": {
                "SafeAccess": "SafeAccessInline\\Integrations\\LaravelFacade"
            }
        }
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/felipesauer"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
