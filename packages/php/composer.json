{
    "name": "safe-access-inline/safe-access-inline",
    "version": "0.3.1",
    "description": "Safe nested data access with dot notation — supports Array, Object, JSON, XML, YAML, TOML, INI, CSV, ENV.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "safe-access",
        "dot-notation",
        "nested-data",
        "json",
        "yaml",
        "plugins"
    ],
    "homepage": "https://github.com/felipesauer/safe-access-inline",
    "authors": [
        {
            "name": "Felipe Sauer",
            "email": "felipesauer11@hotmail.com",
            "homepage": "https://github.com/felipesauer"
        }
    ],
    "support": {
        "issues": "https://github.com/felipesauer/safe-access-inline/issues",
        "source": "https://github.com/felipesauer/safe-access-inline/tree/main/packages/php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-simplexml": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.32.6",
        "devium/toml": "^1.0",
        "symfony/yaml": "^8.0",
        "spatie/phpunit-snapshot-assertions": "^5.3",
        "phpbench/phpbench": "^1.5"
    },
    "suggest": {
        "ext-yaml": "Preferred YAML engine — when installed, used automatically over symfony/yaml for better performance",
        "symfony/yaml": "Required for YAML parsing when ext-yaml is not available (^8.0)",
        "devium/toml": "Required for TOML parsing (^1.0)"
    },
    "autoload": {
        "psr-4": {
            "SafeAccessInline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SafeAccessInline\\Tests\\": "tests/",
            "SafeAccessInline\\PHPStan\\": "phpstan/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "php -d pcov.enabled=1 vendor/bin/pest --coverage-html coverage --coverage-clover coverage.xml",
        "test:parity": "pest tests/CrossParityTest.php",
        "test:snapshot": "pest tests/SnapshotTest.php",
        "test:property": "pest tests/PropertyTest.php",
        "test:fuzzing": "pest tests/FuzzingTest.php",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix",
        "bench": "vendor/bin/phpbench run benchmarks/ --report=aggregate",
        "bench:simple": "php benchmarks/dot-notation.php",
        "test:mutation": [
            "php -d pcov.enabled=1 vendor/bin/pest --coverage-xml=.infection.cache/infection/coverage-xml --log-junit=.infection.cache/infection/junit.xml",
            "php scripts/fix-junit.php",
            "vendor/bin/infection --threads=4 --min-msi=100 --min-covered-msi=100 --coverage=.infection.cache/infection --skip-initial-tests"
        ]
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/felipesauer"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "infection/extension-installer": true
        }
    }
}
