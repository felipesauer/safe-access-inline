{
    "packages/js/**/*.{ts,js}": [
        "packages/js/node_modules/.bin/eslint --config packages/js/eslint.config.js --fix --no-warn-ignored",
        "prettier --write"
    ],
    "packages/cli/**/*.{ts,js}": ["prettier --write"],
    "packages/php/**/*.php": [
        "packages/php/vendor/bin/php-cs-fixer fix --config=packages/php/.php-cs-fixer.dist.php --cache-file=packages/php/.php-cs-fixer.cache"
    ],
    "*.{json,yml,yaml}": ["prettier --write"],
    "*.md": ["prettier --write"]
}
