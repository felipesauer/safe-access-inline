{
    "private": true,
    "name": "safe-access-inline-monorepo",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "description": "Monorepo tooling for safe-access-inline",
    "scripts": {
        "prepare": "husky",
        "test:js": "cd packages/js && npm test",
        "test:cli": "cd packages/cli && npm test",
        "test:php": "cd packages/php && composer test",
        "test": "npm run test:js && npm run test:cli && npm run test:php",
        "lint:js": "cd packages/js && npm run lint",
        "format:js": "cd packages/js && npm run format",
        "format:php": "cd packages/php && composer format",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4",
        "@commitlint/config-conventional": "^20.4",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.3",
        "husky": "^9.0",
        "lint-staged": "^16.3",
        "mermaid": "^11.13.0",
        "prettier": "^3.0",
        "typescript-eslint": "^8.57.1",
        "vitepress": "^1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17"
    },
    "engines": {
        "node": ">=24"
    }
}
